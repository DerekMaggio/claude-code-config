{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash",
      "mcp__github",
      "mcp__atlassian",
      "mcp__claude_ai_Atlassian",
      "Task"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 2
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-commit-docs-check.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/inject_devops_config.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
