{
  "permissions": {
    "allow": [
      "Bash",
      "mcp__github",
      "mcp__atlassian",
      "mcp__claude_ai_Atlassian",
      "Task"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/prefer-gt.py"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__graphite__run_gt_cmd",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre-commit-docs-check.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre-commit-conventional-commit.py"
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-lint.sh\"; if [ -f \"$f\" ]; then bash \"$f\"; else exit 0; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-md-frontmatter.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/inject_devops_config.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 2
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true
}
